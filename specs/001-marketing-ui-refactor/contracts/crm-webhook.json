{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CRM Webhook Payload",
  "description": "Payload sent to the configured CRM webhook when a user submits a contact or demo request.",
  "type": "object",
  "properties": {
    "lead_id": {
      "type": "string",
      "format": "uuid",
      "description": "The Supabase database ID for this lead record."
    },
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "company_name": {
      "type": ["string", "null"]
    },
    "company_size": {
      "type": ["string", "null"],
      "enum": ["1-10", "11-50", "51-200", "200+", null]
    },
    "request_type": {
      "type": "string",
      "enum": ["contact", "demo"]
    },
    "message": {
      "type": ["string", "null"]
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["lead_id", "first_name", "last_name", "email", "request_type", "submitted_at"]
}
